<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:uipath="http://uipath.org/schema/bpmn"
    id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn"
    exporter="UiPath (https://bpmn.uipath.com)" exporterVersion="1.0">
  <bpmn:process id="Process_1" isExecutable="true">
    <bpmn:extensionElements>
      <uipath:migrationVersion version="11.5" />
      <uipath:variables version="v1">
        <uipath:inputOutput id="Var_catalog" name="catalog" type="array" />
        <uipath:inputOutput id="Var_filtered" name="filtered" type="array" />
        <uipath:inputOutput id="Var_readingList" name="readingList" type="array" />
      </uipath:variables>
    </bpmn:extensionElements>

    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_0</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Script task 0: hardcode the catalog (no runtime input required) -->
    <bpmn:scriptTask id="Task_Init" name="Load Catalog" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:scriptVersion value="v3" />
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.ScriptTask" version="v1" />
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{}]]></uipath:input>
          <uipath:output name="catalog" type="array" var="Var_catalog" source="=result.response" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0</bpmn:incoming>
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:script><![CDATA[
return { response: [
  {"title": "Deep Learning", "author": "Goodfellow", "difficulty": 9, "pages": 800},
  {"title": "Statistical Learning", "author": "James", "difficulty": 4, "pages": 440},
  {"title": "Bayesian Data Analysis", "author": "Gelman", "difficulty": 8, "pages": 580},
  {"title": "Information Theory", "author": "MacKay", "difficulty": 7, "pages": 540}
]};
]]></bpmn:script>
    </bpmn:scriptTask>

    <!-- Script task 1: filter to difficulty > 5 AND pages < 600 -->
    <bpmn:scriptTask id="Task_Filter" name="Filter Books" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:scriptVersion value="v3" />
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.ScriptTask" version="v1" />
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"catalog":"=vars.Var_catalog"}]]></uipath:input>
          <uipath:output name="filtered" type="array" var="Var_filtered" source="=result.response" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:script><![CDATA[
var result = catalog.filter(function(book) {
  return book.difficulty > 5 && book.pages < 600;
});
return { response: result };
]]></bpmn:script>
    </bpmn:scriptTask>

    <!-- Script task 2: map survivors to {title (uppercased), author} -->
    <bpmn:scriptTask id="Task_Map" name="Map to Reading List" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:scriptVersion value="v3" />
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.ScriptTask" version="v1" />
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"filtered":"=vars.Var_filtered"}]]></uipath:input>
          <uipath:output name="readingList" type="array" var="Var_readingList" source="=result.response" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:script><![CDATA[
var result = filtered.map(function(book) {
  return { title: book.title.toUpperCase(), author: book.author };
});
return { response: result };
]]></bpmn:script>
    </bpmn:scriptTask>

    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_3</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_0" sourceRef="StartEvent_1" targetRef="Task_Init" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Task_Init" targetRef="Task_Filter" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Filter" targetRef="Task_Map" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_Map" targetRef="EndEvent_1" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="Diagram_1">
    <bpmndi:BPMNPlane id="Plane_1" bpmnElement="Process_1">
      <bpmndi:BPMNShape id="S_StartEvent_1" bpmnElement="StartEvent_1">
        <dc:Bounds x="152" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Task_Init" bpmnElement="Task_Init">
        <dc:Bounds x="250" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Task_Filter" bpmnElement="Task_Filter">
        <dc:Bounds x="410" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Task_Map" bpmnElement="Task_Map">
        <dc:Bounds x="570" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_EndEvent_1" bpmnElement="EndEvent_1">
        <dc:Bounds x="732" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_0" bpmnElement="Flow_0">
        <di:waypoint x="188" y="118" />
        <di:waypoint x="250" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_1" bpmnElement="Flow_1">
        <di:waypoint x="350" y="118" />
        <di:waypoint x="410" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_2" bpmnElement="Flow_2">
        <di:waypoint x="510" y="118" />
        <di:waypoint x="570" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_3" bpmnElement="Flow_3">
        <di:waypoint x="670" y="118" />
        <di:waypoint x="732" y="118" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
