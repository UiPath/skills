<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:uipath="http://uipath.org/schema/bpmn"
    id="Definitions_ExpenseApproval"
    targetNamespace="http://bpmn.io/schema/bpmn"
    exporter="UiPath (https://bpmn.uipath.com)" exporterVersion="1.0">

  <bpmn:process id="Process_ExpenseApproval" isExecutable="true">
    <bpmn:extensionElements>
      <uipath:migrationVersion version="11.5" />
      <uipath:variables version="v1">
        <uipath:inputOutput id="Var_ExpenseAmount"     name="ExpenseAmount"     type="number" />
        <uipath:inputOutput id="Var_RequesterName"     name="RequesterName"     type="string" />
        <uipath:inputOutput id="Var_Category"          name="Category"          type="string" />
        <uipath:inputOutput id="Var_ApprovalDecision"  name="ApprovalDecision"  type="string" />
        <uipath:inputOutput id="Var_ReviewComments"    name="ReviewComments"    type="string" />
      </uipath:variables>
    </bpmn:extensionElements>

    <!-- Manual start event -->
    <bpmn:startEvent id="Start_Manual" name="Start">
      <bpmn:outgoing>Flow_StartToHitl</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- HITL user task: Expense Review -->
    <bpmn:userTask id="UserTask_ExpenseReview" name="Expense Review">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Actions.HITL" version="v1" />
          <uipath:context>
            <uipath:input name="appId"       value="placeholder-expense-review-app-id" />
            <uipath:input name="appVersion"  value="1" />
            <uipath:input name="actions"     value="placeholder-expense-review-actions" />
            <uipath:input name="key"         value="placeholder-expense-review-key" />
            <uipath:input name="taskTitle"   value="Review Expense Request" />
          </uipath:context>
          <uipath:input name="HitlTaskArguments" type="json" target="bodyField"><![CDATA[{
  "expenseAmount": "=vars.Var_ExpenseAmount",
  "requesterName": "=vars.Var_RequesterName",
  "category":      "=vars.Var_Category"
}]]></uipath:input>
          <uipath:output name="Process response" type="Actions.HITL" var="Var_ApprovalDecision" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_StartToHitl</bpmn:incoming>
      <bpmn:outgoing>Flow_HitlToGateway</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Exclusive gateway: branch on decision -->
    <bpmn:exclusiveGateway id="Gw_DecisionBranch" name="Approved?" default="Flow_GatewayToRejected">
      <bpmn:incoming>Flow_HitlToGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_GatewayToApproved</bpmn:outgoing>
      <bpmn:outgoing>Flow_GatewayToRejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Approval end: record the approval -->
    <bpmn:endEvent id="End_Approved" name="Expense Approved">
      <bpmn:incoming>Flow_GatewayToApproved</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Rejection end: process ends without approval -->
    <bpmn:endEvent id="End_Rejected" name="Expense Rejected">
      <bpmn:incoming>Flow_GatewayToRejected</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence flows -->
    <bpmn:sequenceFlow id="Flow_StartToHitl"
                       sourceRef="Start_Manual"
                       targetRef="UserTask_ExpenseReview" />

    <bpmn:sequenceFlow id="Flow_HitlToGateway"
                       sourceRef="UserTask_ExpenseReview"
                       targetRef="Gw_DecisionBranch" />

    <bpmn:sequenceFlow id="Flow_GatewayToApproved"
                       sourceRef="Gw_DecisionBranch"
                       targetRef="End_Approved">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=vars.Var_ApprovalDecision == "approved"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_GatewayToRejected"
                       sourceRef="Gw_DecisionBranch"
                       targetRef="End_Rejected" />

  </bpmn:process>

  <!-- BPMN Diagram Interchange -->
  <bpmndi:BPMNDiagram id="Diagram_1">
    <bpmndi:BPMNPlane id="Plane_1" bpmnElement="Process_ExpenseApproval">

      <!-- Start event -->
      <bpmndi:BPMNShape id="S_Start_Manual" bpmnElement="Start_Manual">
        <dc:Bounds x="160" y="102" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- HITL user task -->
      <bpmndi:BPMNShape id="S_UserTask_ExpenseReview" bpmnElement="UserTask_ExpenseReview">
        <dc:Bounds x="260" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Exclusive gateway -->
      <bpmndi:BPMNShape id="S_Gw_DecisionBranch" bpmnElement="Gw_DecisionBranch">
        <dc:Bounds x="430" y="95" width="50" height="50" />
      </bpmndi:BPMNShape>

      <!-- Approved end event -->
      <bpmndi:BPMNShape id="S_End_Approved" bpmnElement="End_Approved">
        <dc:Bounds x="560" y="42" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- Rejected end event -->
      <bpmndi:BPMNShape id="S_End_Rejected" bpmnElement="End_Rejected">
        <dc:Bounds x="560" y="162" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- Flow: Start -> HITL -->
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_StartToHitl" bpmnElement="Flow_StartToHitl">
        <di:waypoint x="196" y="120" />
        <di:waypoint x="260" y="120" />
      </bpmndi:BPMNEdge>

      <!-- Flow: HITL -> Gateway -->
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_HitlToGateway" bpmnElement="Flow_HitlToGateway">
        <di:waypoint x="360" y="120" />
        <di:waypoint x="430" y="120" />
      </bpmndi:BPMNEdge>

      <!-- Flow: Gateway -> Approved (condition branch) -->
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_GatewayToApproved" bpmnElement="Flow_GatewayToApproved">
        <di:waypoint x="455" y="95" />
        <di:waypoint x="455" y="60" />
        <di:waypoint x="560" y="60" />
      </bpmndi:BPMNEdge>

      <!-- Flow: Gateway -> Rejected (default branch) -->
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_GatewayToRejected" bpmnElement="Flow_GatewayToRejected">
        <di:waypoint x="455" y="145" />
        <di:waypoint x="455" y="180" />
        <di:waypoint x="560" y="180" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
