<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:uipath="http://uipath.org/schema/bpmn"
    id="Definitions_InvoiceTriageBpmn"
    targetNamespace="http://bpmn.io/schema/bpmn"
    exporter="UiPath (https://bpmn.uipath.com)" exporterVersion="1.0">

  <bpmn:process id="Process_InvoiceTriage" isExecutable="true">
    <bpmn:extensionElements>
      <uipath:migrationVersion version="11.5" />
      <uipath:variables version="v1">
        <!-- Input variables scoped to the start event -->
        <uipath:inputOutput id="Var_invoiceId" name="invoiceId" type="string" elementId="Start_ManualInvoice" />
        <uipath:inputOutput id="Var_amount" name="amount" type="number" elementId="Start_ManualInvoice" />
      </uipath:variables>
    </bpmn:extensionElements>

    <!-- START: Manual start event -->
    <bpmn:startEvent id="Start_ManualInvoice" name="Invoice Received">
      <bpmn:extensionElements>
        <uipath:entryPointId value="ep_InvoiceTriageStart" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_Start_to_RecordIntake</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- TASK: Record Invoice Intake -->
    <bpmn:task id="Task_RecordIntake" name="Record Invoice Intake">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_to_RecordIntake</bpmn:incoming>
      <bpmn:outgoing>Flow_RecordIntake_to_ExclGw</bpmn:outgoing>
    </bpmn:task>

    <!-- EXCLUSIVE GATEWAY: Route by amount -->
    <bpmn:exclusiveGateway id="Gw_AmountCheck" name="High-Value?" default="Flow_ExclGw_to_AutoApproval">
      <bpmn:incoming>Flow_RecordIntake_to_ExclGw</bpmn:incoming>
      <bpmn:outgoing>Flow_ExclGw_to_ManagerReview</bpmn:outgoing>
      <bpmn:outgoing>Flow_ExclGw_to_AutoApproval</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- TASK: Manager Review (high-value path) -->
    <bpmn:task id="Task_ManagerReview" name="Manager Review">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ExclGw_to_ManagerReview</bpmn:incoming>
      <bpmn:outgoing>Flow_ManagerReview_to_ParallelFork</bpmn:outgoing>
    </bpmn:task>

    <!-- TASK: Auto Approval (default path) -->
    <bpmn:task id="Task_AutoApproval" name="Auto Approval">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ExclGw_to_AutoApproval</bpmn:incoming>
      <bpmn:outgoing>Flow_AutoApproval_to_ParallelFork</bpmn:outgoing>
    </bpmn:task>

    <!-- PARALLEL GATEWAY: Fork into two follow-up tasks -->
    <bpmn:parallelGateway id="Gw_ParallelFork" name="Start Follow-ups">
      <bpmn:incoming>Flow_ManagerReview_to_ParallelFork</bpmn:incoming>
      <bpmn:incoming>Flow_AutoApproval_to_ParallelFork</bpmn:incoming>
      <bpmn:outgoing>Flow_Fork_to_NotifyRequester</bpmn:outgoing>
      <bpmn:outgoing>Flow_Fork_to_ArchiveDecision</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- TASK: Notify Requester -->
    <bpmn:task id="Task_NotifyRequester" name="Notify Requester">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Fork_to_NotifyRequester</bpmn:incoming>
      <bpmn:outgoing>Flow_NotifyRequester_to_ParallelJoin</bpmn:outgoing>
    </bpmn:task>

    <!-- TASK: Archive Decision -->
    <bpmn:task id="Task_ArchiveDecision" name="Archive Decision">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Fork_to_ArchiveDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_ArchiveDecision_to_ParallelJoin</bpmn:outgoing>
    </bpmn:task>

    <!-- PARALLEL GATEWAY: Join before end -->
    <bpmn:parallelGateway id="Gw_ParallelJoin" name="Await Follow-ups">
      <bpmn:incoming>Flow_NotifyRequester_to_ParallelJoin</bpmn:incoming>
      <bpmn:incoming>Flow_ArchiveDecision_to_ParallelJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_ParallelJoin_to_End</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- END EVENT -->
    <bpmn:endEvent id="End_InvoiceProcessed" name="Invoice Processed">
      <bpmn:incoming>Flow_ParallelJoin_to_End</bpmn:incoming>
    </bpmn:endEvent>

    <!-- SEQUENCE FLOWS -->
    <bpmn:sequenceFlow id="Flow_Start_to_RecordIntake"
      name="Start to Record Intake"
      sourceRef="Start_ManualInvoice" targetRef="Task_RecordIntake" />

    <bpmn:sequenceFlow id="Flow_RecordIntake_to_ExclGw"
      name="Intake to Amount Check"
      sourceRef="Task_RecordIntake" targetRef="Gw_AmountCheck" />

    <!-- High-value condition: amount >= 1000 -->
    <bpmn:sequenceFlow id="Flow_ExclGw_to_ManagerReview"
      name="High-Value (>= 1000)"
      sourceRef="Gw_AmountCheck" targetRef="Task_ManagerReview">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=vars.Var_amount &gt;= 1000</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <!-- Default route: all other invoices -->
    <bpmn:sequenceFlow id="Flow_ExclGw_to_AutoApproval"
      name="Auto Approve (default)"
      sourceRef="Gw_AmountCheck" targetRef="Task_AutoApproval" />

    <bpmn:sequenceFlow id="Flow_ManagerReview_to_ParallelFork"
      name="Manager Review Done"
      sourceRef="Task_ManagerReview" targetRef="Gw_ParallelFork" />

    <bpmn:sequenceFlow id="Flow_AutoApproval_to_ParallelFork"
      name="Auto Approval Done"
      sourceRef="Task_AutoApproval" targetRef="Gw_ParallelFork" />

    <bpmn:sequenceFlow id="Flow_Fork_to_NotifyRequester"
      name="Notify Branch"
      sourceRef="Gw_ParallelFork" targetRef="Task_NotifyRequester" />

    <bpmn:sequenceFlow id="Flow_Fork_to_ArchiveDecision"
      name="Archive Branch"
      sourceRef="Gw_ParallelFork" targetRef="Task_ArchiveDecision" />

    <bpmn:sequenceFlow id="Flow_NotifyRequester_to_ParallelJoin"
      name="Notify Done"
      sourceRef="Task_NotifyRequester" targetRef="Gw_ParallelJoin" />

    <bpmn:sequenceFlow id="Flow_ArchiveDecision_to_ParallelJoin"
      name="Archive Done"
      sourceRef="Task_ArchiveDecision" targetRef="Gw_ParallelJoin" />

    <bpmn:sequenceFlow id="Flow_ParallelJoin_to_End"
      name="To End"
      sourceRef="Gw_ParallelJoin" targetRef="End_InvoiceProcessed" />

  </bpmn:process>

  <!-- Diagram placeholder - will be replaced by generate_diagram.py -->


  <bpmndi:BPMNDiagram id="Diagram_1">
    <bpmndi:BPMNPlane id="Plane_1" bpmnElement="Process_InvoiceTriage">
      <bpmndi:BPMNShape id="S_End_InvoiceProcessed" bpmnElement="End_InvoiceProcessed"><dc:Bounds x="1066" y="100" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Gw_AmountCheck" bpmnElement="Gw_AmountCheck"><dc:Bounds x="416" y="100" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Gw_ParallelFork" bpmnElement="Gw_ParallelFork"><dc:Bounds x="686" y="100" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Gw_ParallelJoin" bpmnElement="Gw_ParallelJoin"><dc:Bounds x="956" y="100" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Start_ManualInvoice" bpmnElement="Start_ManualInvoice"><dc:Bounds x="160" y="100" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Task_ArchiveDecision" bpmnElement="Task_ArchiveDecision"><dc:Bounds x="796" y="100" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Task_AutoApproval" bpmnElement="Task_AutoApproval"><dc:Bounds x="526" y="100" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Task_ManagerReview" bpmnElement="Task_ManagerReview"><dc:Bounds x="526" y="210" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Task_NotifyRequester" bpmnElement="Task_NotifyRequester"><dc:Bounds x="796" y="210" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Task_RecordIntake" bpmnElement="Task_RecordIntake"><dc:Bounds x="256" y="100" width="100" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_Flow_ArchiveDecision_to_ParallelJoin" bpmnElement="Flow_ArchiveDecision_to_ParallelJoin"><di:waypoint x="846" y="140" /><di:waypoint x="981" y="125" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_Flow_AutoApproval_to_ParallelFork" bpmnElement="Flow_AutoApproval_to_ParallelFork"><di:waypoint x="576" y="140" /><di:waypoint x="711" y="125" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_Flow_ExclGw_to_AutoApproval" bpmnElement="Flow_ExclGw_to_AutoApproval"><di:waypoint x="441" y="125" /><di:waypoint x="576" y="140" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_Flow_ExclGw_to_ManagerReview" bpmnElement="Flow_ExclGw_to_ManagerReview"><di:waypoint x="441" y="125" /><di:waypoint x="576" y="250" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_Flow_Fork_to_ArchiveDecision" bpmnElement="Flow_Fork_to_ArchiveDecision"><di:waypoint x="711" y="125" /><di:waypoint x="846" y="140" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_Flow_Fork_to_NotifyRequester" bpmnElement="Flow_Fork_to_NotifyRequester"><di:waypoint x="711" y="125" /><di:waypoint x="846" y="250" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_Flow_ManagerReview_to_ParallelFork" bpmnElement="Flow_ManagerReview_to_ParallelFork"><di:waypoint x="576" y="250" /><di:waypoint x="711" y="125" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_Flow_NotifyRequester_to_ParallelJoin" bpmnElement="Flow_NotifyRequester_to_ParallelJoin"><di:waypoint x="846" y="250" /><di:waypoint x="981" y="125" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_Flow_ParallelJoin_to_End" bpmnElement="Flow_ParallelJoin_to_End"><di:waypoint x="981" y="125" /><di:waypoint x="1084" y="118" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_Flow_RecordIntake_to_ExclGw" bpmnElement="Flow_RecordIntake_to_ExclGw"><di:waypoint x="306" y="140" /><di:waypoint x="441" y="125" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_Flow_Start_to_RecordIntake" bpmnElement="Flow_Start_to_RecordIntake"><di:waypoint x="178" y="118" /><di:waypoint x="306" y="140" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
