<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:uipath="http://uipath.org/schema/bpmn"
    id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn"
    exporter="UiPath (https://bpmn.uipath.com)" exporterVersion="1.0">
  <bpmn:process id="Process_1" isExecutable="true">
    <bpmn:extensionElements>
      <uipath:migrationVersion version="11.5" />
      <uipath:variables version="v1">
        <uipath:inputOutput id="Var_catalog" name="catalog" type="object" />
        <uipath:inputOutput id="Var_filtered" name="filtered" type="object" />
        <uipath:inputOutput id="Var_readingList" name="readingList" type="object" />
      </uipath:variables>
    </bpmn:extensionElements>

    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:scriptTask id="Task_Filter" name="Filter Books" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:scriptVersion value="v3" />
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.ScriptTask" version="v1" />
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"catalog":[{"title":"Deep Learning","author":"Goodfellow","difficulty":9,"pages":800},{"title":"Statistical Learning","author":"James","difficulty":4,"pages":440},{"title":"Bayesian Data Analysis","author":"Gelman","difficulty":8,"pages":580},{"title":"Information Theory","author":"MacKay","difficulty":7,"pages":540}]}]]></uipath:input>
          <uipath:output name="catalog_out" type="object" var="Var_catalog" source="=result.response.catalog" />
          <uipath:output name="filtered_out" type="object" var="Var_filtered" source="=result.response.filtered" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:script><![CDATA[var filtered = catalog.filter(function(b) { return b.difficulty > 5 && b.pages < 600; });
return { response: { catalog: catalog, filtered: filtered } };]]></bpmn:script>
    </bpmn:scriptTask>

    <bpmn:scriptTask id="Task_Map" name="Map to Reading List" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:scriptVersion value="v3" />
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.ScriptTask" version="v1" />
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"filtered":"=vars.Var_filtered"}]]></uipath:input>
          <uipath:output name="readingList_out" type="object" var="Var_readingList" source="=result.response" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:script><![CDATA[var curated = filtered.map(function(b) { return { title: b.title.toUpperCase(), author: b.author }; });
return { response: curated };]]></bpmn:script>
    </bpmn:scriptTask>

    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_3</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_Filter" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Filter" targetRef="Task_Map" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_Map" targetRef="EndEvent_1" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="Diagram_1">
    <bpmndi:BPMNPlane id="Plane_1" bpmnElement="Process_1">
      <bpmndi:BPMNShape id="S_StartEvent_1" bpmnElement="StartEvent_1">
        <dc:Bounds x="160" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Task_Filter" bpmnElement="Task_Filter">
        <dc:Bounds x="260" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Task_Map" bpmnElement="Task_Map">
        <dc:Bounds x="420" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_EndEvent_1" bpmnElement="EndEvent_1">
        <dc:Bounds x="582" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_1" bpmnElement="Flow_1">
        <di:waypoint x="196" y="118" />
        <di:waypoint x="260" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_2" bpmnElement="Flow_2">
        <di:waypoint x="360" y="118" />
        <di:waypoint x="420" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_3" bpmnElement="Flow_3">
        <di:waypoint x="520" y="118" />
        <di:waypoint x="582" y="118" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
