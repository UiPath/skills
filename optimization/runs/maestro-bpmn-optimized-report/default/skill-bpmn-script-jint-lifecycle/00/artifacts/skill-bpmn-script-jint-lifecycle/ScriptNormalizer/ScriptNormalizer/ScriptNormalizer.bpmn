<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:uipath="http://uipath.org/schema/bpmn"
    id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn"
    exporter="UiPath (https://bpmn.uipath.com)" exporterVersion="1.0">

  <bpmn:process id="Process_1" isExecutable="true">
    <bpmn:extensionElements>
      <uipath:migrationVersion version="11.5" />
      <uipath:variables version="v1">
        <uipath:inputOutput id="Var_RawRequest" name="rawRequest" type="string" elementId="StartEvent_1" />
        <uipath:inputOutput id="Var_NormalizedResponse" name="normalizedResponse" type="object" />
      </uipath:variables>
    </bpmn:extensionElements>

    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:extensionElements>
        <uipath:entryPointId value="EntryPoint_ManualStart" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:scriptTask id="Task_NormalizeRequest" name="Normalize Request" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:scriptVersion value="v3" />
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.ScriptTask" version="v1" />
          <uipath:input name="args" type="json" target="bodyField"><![CDATA[{"rawRequest":"=vars.Var_RawRequest"}]]></uipath:input>
          <uipath:output name="normalizedResponse" type="object" var="Var_NormalizedResponse" source="=result.response" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:script><![CDATA[
var parsed;
if (typeof rawRequest === 'string') {
  try {
    parsed = JSON.parse(rawRequest);
  } catch (e) {
    parsed = { raw: rawRequest };
  }
} else if (rawRequest !== null && typeof rawRequest === 'object') {
  parsed = rawRequest;
} else {
  parsed = { raw: String(rawRequest) };
}

var normalized = {
  method: (typeof parsed.method === 'string') ? parsed.method.toUpperCase() : 'GET',
  path: (typeof parsed.path === 'string') ? parsed.path.replace(/\/+$/, '') || '/' : '/',
  headers: (parsed.headers !== null && typeof parsed.headers === 'object') ? parsed.headers : {},
  body: (parsed.body !== undefined) ? parsed.body : null,
  queryParams: (parsed.queryParams !== null && typeof parsed.queryParams === 'object') ? parsed.queryParams : {},
  normalizedAt: (new Date()).toISOString()
};

return { response: normalized };
]]></bpmn:script>
    </bpmn:scriptTask>

    <bpmn:endEvent id="EndEvent_1" name="Done">
      <bpmn:incoming>Flow_2</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_NormalizeRequest" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_NormalizeRequest" targetRef="EndEvent_1" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="Diagram_1">
    <bpmndi:BPMNPlane id="Plane_1" bpmnElement="Process_1">
      <bpmndi:BPMNShape id="S_StartEvent_1" bpmnElement="StartEvent_1">
        <dc:Bounds x="160" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Task_NormalizeRequest" bpmnElement="Task_NormalizeRequest">
        <dc:Bounds x="260" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_EndEvent_1" bpmnElement="EndEvent_1">
        <dc:Bounds x="422" y="100" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_1" bpmnElement="Flow_1">
        <di:waypoint x="196" y="118" />
        <di:waypoint x="260" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_2" bpmnElement="Flow_2">
        <di:waypoint x="360" y="118" />
        <di:waypoint x="422" y="118" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
