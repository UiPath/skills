      ],
      "model": {
        "type": "bpmn:Task"
      },
      "outputDefinition": {
        "output": {
          "type": "object",
          "description": "Mock output value",
          "source": "null",
          "var": "output"
        }
      }
    },
    {
      "nodeType": "core.logic.loop",
