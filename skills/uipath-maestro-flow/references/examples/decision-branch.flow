        "icon": "play",
        "shape": "circle",
        "iconBackground": "linear-gradient(225deg, #FAFAFB 0%, #ECEDEF 100%)",
        "iconBackgroundDark": "linear-gradient(225deg, #526069 0%, rgba(50, 60, 66, 0.6) 100%)"
      },
      "handleConfiguration": [
        {
          "position": "right",
          "handles": [
            {
              "id": "output",
              "type": "source",
              "handleType": "output",
