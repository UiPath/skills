<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:uipath="http://uipath.org/schema/bpmn" id="Definitions_Invalid" targetNamespace="http://uipath.com/synthetic/maestro-bpmn/invalid">
  <bpmn:process id="Process_Invalid" name="Invalid Sample" isExecutable="true">
    <bpmn:extensionElements>
      <uipath:variables version="v1">
        <uipath:input id="Var_RequestType" name="requestType" type="string" elementId="Start_Manual" />
      </uipath:variables>
    </bpmn:extensionElements>
    <bpmn:startEvent id="Start_Manual" name="Start">
      <bpmn:outgoing>Flow_Start_To_Gateway</bpmn:outgoing>
    </bpmn:startEvent>
    <!-- BAD: exclusive gateway with two outgoing flows, no default and no conditions -->
    <bpmn:exclusiveGateway id="Gateway_NoDefault" name="No Default">
      <bpmn:incoming>Flow_Start_To_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Gateway_To_Review</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gateway_To_Archive</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Review" name="Review">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="UiPath.Custom" version="v1" />
          <!-- BAD: references a variable that does not exist -->
          <uipath:input name="payload" type="json"><![CDATA[{"type":"=vars.DoesNotExist"}]]></uipath:input>
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gateway_To_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_Review_To_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Archive" name="Archive">
      <bpmn:incoming>Flow_Gateway_To_Archive</bpmn:incoming>
      <bpmn:outgoing>Flow_Archive_To_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Complete" name="Complete">
      <bpmn:incoming>Flow_Review_To_End</bpmn:incoming>
      <bpmn:incoming>Flow_Archive_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_Gateway" sourceRef="Start_Manual" targetRef="Gateway_NoDefault" />
    <bpmn:sequenceFlow id="Flow_Gateway_To_Review" sourceRef="Gateway_NoDefault" targetRef="Task_Review" />
    <bpmn:sequenceFlow id="Flow_Gateway_To_Archive" sourceRef="Gateway_NoDefault" targetRef="Task_Archive" />
    <bpmn:sequenceFlow id="Flow_Review_To_End" sourceRef="Task_Review" targetRef="End_Complete" />
    <bpmn:sequenceFlow id="Flow_Archive_To_End" sourceRef="Task_Archive" targetRef="End_Complete" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_Invalid">
    <bpmndi:BPMNPlane id="Plane_Invalid" bpmnElement="Process_Invalid">
      <bpmndi:BPMNShape id="Shape_Start_Manual" bpmnElement="Start_Manual"><dc:Bounds x="100" y="160" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_NoDefault" bpmnElement="Gateway_NoDefault" isMarkerVisible="true"><dc:Bounds x="200" y="153" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Review" bpmnElement="Task_Review"><dc:Bounds x="320" y="96" width="140" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Archive" bpmnElement="Task_Archive"><dc:Bounds x="320" y="230" width="140" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_Complete" bpmnElement="End_Complete"><dc:Bounds x="540" y="160" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_Start_To_Gateway" bpmnElement="Flow_Start_To_Gateway"><di:waypoint x="136" y="178" /><di:waypoint x="200" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Gateway_To_Review" bpmnElement="Flow_Gateway_To_Review"><di:waypoint x="225" y="153" /><di:waypoint x="320" y="136" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Gateway_To_Archive" bpmnElement="Flow_Gateway_To_Archive"><di:waypoint x="225" y="203" /><di:waypoint x="320" y="270" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Review_To_End" bpmnElement="Flow_Review_To_End"><di:waypoint x="460" y="136" /><di:waypoint x="540" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Archive_To_End" bpmnElement="Flow_Archive_To_End"><di:waypoint x="460" y="270" /><di:waypoint x="540" y="178" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
