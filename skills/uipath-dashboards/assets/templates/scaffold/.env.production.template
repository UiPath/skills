# Production build. PAT MUST be absent — vite.config.ts aborts the build
# if VITE_UIPATH_PAT is detected in any loaded env file. The deploy flow
# temp-moves .env.local aside for the production build so the SDK's
# ActionCenterTokenManager handles tokens at runtime.
#
# baseUrl pattern (API subdomain, NOT the portal URL):
#   alpha   → https://alpha.api.uipath.com
#   staging → https://staging.api.uipath.com
#   cloud   → https://api.uipath.com
VITE_UIPATH_BASE_URL={{baseUrl}}
VITE_UIPATH_ORG_NAME={{orgName}}
VITE_UIPATH_TENANT_NAME={{tenantName}}
