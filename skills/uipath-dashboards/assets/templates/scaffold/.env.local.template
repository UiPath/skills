# Local dev only — NEVER commit. Generate a PAT at:
#   https://{{env}}.uipath.com/{{orgName}}/{{tenantName}}/portal_/accessTokens
# Minimum scope: what this dashboard needs (see scopes listed in state.json).
#
# Use the portal URL (uipath.com), NOT the API subdomain (api.uipath.com).
# The TS SDK constructs internal API paths itself; baseUrl is the portal origin
# and MUST match the UIPATH_URL recorded in ~/.uipath/.auth after `uip login`.
# Wrong: https://{{env}}.api.uipath.com — silent 404s at runtime.
VITE_UIPATH_BASE_URL=https://{{env}}.uipath.com
VITE_UIPATH_ORG_NAME={{orgName}}
VITE_UIPATH_TENANT_NAME={{tenantName}}
VITE_UIPATH_PAT=
