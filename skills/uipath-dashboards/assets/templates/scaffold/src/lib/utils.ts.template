import { clsx, type ClassValue } from 'clsx';
import { twMerge } from 'tailwind-merge';

/**
 * Tailwind className merger. This is the ONLY thing in utils.ts.
 *
 * Why only `cn()`: `shadcn init` regenerates this file with only `cn()` as
 * its content. Anything else we put here gets wiped. All dashboard primitives
 * (zeroFill, groupBy, etc.) live in `src/lib/queries/_shared.ts` instead.
 */
export function cn(...inputs: ClassValue[]) {
  return twMerge(clsx(inputs));
}
