<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Meta tags below are injected at runtime by the Apps host (v2+) or left empty in dev -->
    <meta name="uipath:basedomain" content="" />
    <meta name="uipath:secret" content="" />
    <title>{{name}}</title>
    <script>
      // Apply stored theme before React mounts to avoid flash-of-unthemed-content.
      // Default = light. Dark only if explicitly stored by the toggle.
      (function () {
        try {
          if (localStorage.getItem('uipath-dashboard-theme') === 'dark') {
            document.documentElement.classList.add('dark');
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    <div id="root"></div>
    <script type="module" src="/src/main.tsx"></script>
  </body>
</html>
