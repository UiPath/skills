{
  "version": 2,
  "_doc": "Faithful-style replay of unattended job 7b2e1c04-9f3a-4d21-8c6e-2a5f9b1d3e40 (folder Shared). Scrubbed (host->MOCK-HOST, account->UIPATH\\AUTOMATION1).",
  "rules": [
    {
      "match": "or jobs logs 7b2e1c04-9f3a-4d21-8c6e-2a5f9b1d3e40 --level Error",
      "file": "joblogs-error.json"
    },
    {
      "match": "or jobs logs 7b2e1c04-9f3a-4d21-8c6e-2a5f9b1d3e40",
      "file": "joblogs.json"
    },
    {
      "match": "or jobs get 7b2e1c04-9f3a-4d21-8c6e-2a5f9b1d3e40",
      "file": "jobget.json"
    },
    {
      "match": "or jobs history 7b2e1c04-9f3a-4d21-8c6e-2a5f9b1d3e40",
      "file": "jobhistory.json"
    },
    {
      "match": "or jobs traces 7b2e1c04-9f3a-4d21-8c6e-2a5f9b1d3e40",
      "file": "jobtraces.json"
    },
    {
      "match": "traces spans get --job-key 7b2e1c04-9f3a-4d21-8c6e-2a5f9b1d3e40",
      "file": "spans-fail.json",
      "exit_code": 1
    },
    {
      "match": "or jobs list --folder-key c1a2b3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5d --state Faulted",
      "file": "joblist.json"
    },
    {
      "match": "or jobs list --folder-key c1a2b3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5d",
      "file": "joblist.json"
    },
    {
      "match": "or jobs list",
      "file": "joblist.json"
    },
    {
      "match": "or folders list",
      "file": "folders.json"
    },
    {
      "match": "docsai ask",
      "passthrough": true
    }
  ],
  "unmocked_default": {
    "response": {
      "Result": "Success",
      "Code": "Empty",
      "Data": []
    },
    "exit_code": 0,
    "_doc": "Empty result for any unmatched read-only uip query."
  }
}
