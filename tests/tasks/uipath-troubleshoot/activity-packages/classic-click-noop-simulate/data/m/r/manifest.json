{
  "version": 2,
  "rules": [
    {
      "match": "or folders list",
      "file": "10fold.json"
    },
    {
      "match": "or jobs list",
      "file": "20jobs.json"
    },
    {
      "match": "or jobs get 3b9c2d1e-4f5a-4b6c-8d7e-9f0a1b2c3d4e",
      "file": "30jobg.json"
    },
    {
      "match": "or jobs logs 3b9c2d1e-4f5a-4b6c-8d7e-9f0a1b2c3d4e --level Error",
      "file": "40errl.json"
    },
    {
      "match": "or jobs logs 3b9c2d1e-4f5a-4b6c-8d7e-9f0a1b2c3d4e",
      "file": "50infl.json"
    },
    {
      "match": "docsai ask",
      "passthrough": true
    }
  ],
  "unmocked_default": {
    "response": "[]\n",
    "exit_code": 0
  }
}
