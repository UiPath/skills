  <Sequence DisplayName="Create CRM Contact">
    <ui:HttpClient DisplayName="HTTP Request" EndPoint="https://crm.vendor.example/api/v2/contacts" Method="POST" BodyFormat="application/xml" Body="{&quot;name&quot;:&quot;Acme Corp&quot;,&quot;email&quot;:&quot;ops@acme.example&quot;,&quot;tier&quot;:&quot;gold&quot;}" TimeoutMS="30000" />
  </Sequence>
