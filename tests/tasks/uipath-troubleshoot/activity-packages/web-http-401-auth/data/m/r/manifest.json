    },
    {
      "match": "or jobs list --folder-key e5f6a7b8-c9d0-4e1f-8a2b-3c4d5e6f7a8b",
      "file": "joblist.json"
    },
    {
      "match": "or jobs list",
      "file": "joblist.json"
    },
    {
      "match": "or folders list",
      "file": "folders.json"
    },
    {
      "match": "docsai ask",
      "passthrough": true
    }
  ],
  "unmocked_default": {
    "response": {
      "Result": "Success",
      "Code": "Empty",
      "Data": []
    },
    "exit_code": 0,
    "_doc": "Empty result for any unmatched read-only uip query."
  }
