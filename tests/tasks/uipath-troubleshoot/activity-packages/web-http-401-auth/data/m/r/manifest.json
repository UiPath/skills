{
  "version": 2,
  "_doc": "Faithful-style replay of job 9d4f2a18-3c5b-4e70-8a2f-1b6c3e5d7a90 (folder Shared). Scrubbed (host->MOCK-HOST, account->UIPATH\\AUTOMATION1).",
  "rules": [
    {
      "match": "or jobs logs 9d4f2a18-3c5b-4e70-8a2f-1b6c3e5d7a90 --level Error",
      "file": "joblogs-error.json"
    },
    {
      "match": "or jobs logs 9d4f2a18-3c5b-4e70-8a2f-1b6c3e5d7a90",
      "file": "joblogs.json"
    },
    {
      "match": "or jobs get 9d4f2a18-3c5b-4e70-8a2f-1b6c3e5d7a90",
      "file": "jobget.json"
    },
    {
      "match": "or jobs history 9d4f2a18-3c5b-4e70-8a2f-1b6c3e5d7a90",
      "file": "jobhistory.json"
    },
    {
      "match": "or jobs traces 9d4f2a18-3c5b-4e70-8a2f-1b6c3e5d7a90",
      "file": "jobtraces.json"
    },
    {
      "match": "traces spans get --job-key 9d4f2a18-3c5b-4e70-8a2f-1b6c3e5d7a90",
