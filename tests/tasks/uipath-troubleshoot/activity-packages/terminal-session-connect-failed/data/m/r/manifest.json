{
  "version": 2,
  "_doc": "Faithful replay of a faulted UiPath.Terminal.Activities TerminalSession job. Canned uip CLI responses captured from a real Orchestrator job; PII scrubbed. First-match-wins.",
  "rules": [
    {
      "match": "or folders list",
      "file": "9e896197b8.json"
    },
    {
      "match": "or jobs list --folder-key 1a2b3c4d-5e6f-4a7b-8c9d-0e1f2a3b4c5d --state Faulted",
      "file": "5be442c927.json"
    },
    {
      "match": "or jobs list --folder-key 1a2b3c4d-5e6f-4a7b-8c9d-0e1f2a3b4c5d",
      "file": "5be442c927.json"
    },
    {
      "match": "or jobs list",
      "file": "5be442c927.json"
    },
    {
      "match": "or jobs get caf901ab-28a3-4621-bcfa-68a0447e49c8",
      "file": "4a4735f979.json"
    },
    {
      "match": "or jobs logs caf901ab-28a3-4621-bcfa-68a0447e49c8 --level Error",
      "file": "e995b39aaa.json"
    },
    {
      "match": "or jobs logs caf901ab-28a3-4621-bcfa-68a0447e49c8",
      "file": "e995b39aaa.json"
    },
    {
      "match": "or jobs traces caf901ab-28a3-4621-bcfa-68a0447e49c8",
      "file": "2d930e2440.json"
    },
    {
      "match": "traces spans get --job-key caf901ab-28a3-4621-bcfa-68a0447e49c8",
      "file": "56a91ad33d.json"
    },
    {
      "match": "docsai ask",
      "passthrough": true
    }
  ],
  "unmocked_default": {
    "response": "[]\n",
    "exit_code": 0,
    "_doc": "Permissive fallback: any uip command not matched returns an empty array so the agent can explore beyond the recorded path without aborting."
  },
  "expected_calls": [
    {
      "pattern": "or jobs list",
      "min": 1,
      "description": "Agent lists faulted jobs in the Shared folder to find the failing job (prompt gives no job key)."
    },
    {
      "pattern": "or jobs get caf901ab-28a3-4621-bcfa-68a0447e49c8",
      "min": 1,
      "description": "Agent fetches the faulted job to read its exception detail."
    }
  ]
}
