      "file": "or-jobs-logs-a6d9f7bc-output-json.json"
    },
    {
      "match": "or jobs logs a6d9f7bc-8ca3-4fb0-91d2-6d7e8f901234 --output json",
      "file": "or-jobs-logs-a6d9f7bc-output-json.json"
    },
    {
      "match": "docsai ask",
