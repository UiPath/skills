{
  "version": 2,
  "_doc": "Auto-generated by generate_scenario.py \u2014 review fixtures + add expected_calls.",
  "rules": [
    {
      "match": "docsai ask",
      "passthrough": true,
      "_doc": "Per CLAUDE.md: docsai queries always passthrough — query strings vary between runs and canned responses go stale. Cached per-query within a run."
    },
    {
      "match": "or jobs logs 0f9d854e-221e-487d-bb2b-fcc76a7d7461 --output json",
      "file": "or-jobs-logs-0f9d854e-221e-487d-bb2b-fcc76a7d7461-output-jso.json"
    },
    {
      "match": "or jobs history 0f9d854e-221e-487d-bb2b-fcc76a7d7461 --output json",
      "file": "or-jobs-history-0f9d854e-221e-487d-bb2b-fcc76a7d7461-output-.json"
    },
    {
      "match": "or machines list --output json",
      "file": "or-machines-list-output-json.json"
    },
    {
      "match": "or licenses info --output json",
      "file": "or-licenses-info-output-json.json"
    },
    {
      "match": "or folders list --output json",
      "file": "or-folders-list-output-json.json"
    },
    {
      "match": "or jobs get 75b781fd-0d8f-4844-a3e8-3f74a4ac6f46",
      "file": "or-jobs-get-75b781fd-0d8f-4844-a3e8-3f74a4ac6f46-output-json.json",
      "exit_code": 1,
      "_doc": "Wrong job key (it's actually a LicenseKey of danVM). Returns HTTP 404. Catches any `or jobs get 75b781fd-...` variant — prompts the simulation persona to supply the correct key 0f9d854e-..."
    },
    {
      "match": "or jobs list --folder-key 1965a46b-db4e-469e-aaaa-7e0b379cb34d --output json",
      "file": "or-jobs-list-folder-key-1965a46b-db4e-469e-aaaa-7e0b379cb34d.json"
    },
    {
      "match": "or jobs list --folder-key dea5d8d6-ca39-4dbf-b4a5-3516bad38866 --output json",
      "file": "or-jobs-list-folder-key-dea5d8d6-ca39-4dbf-b4a5-3516bad38866.json"
    },
    {
      "match": "or jobs list --folder-key 1965a46b-db4e-469e-aaaa-7e0b379cb34d --state Pending --output json",
      "file": "or-jobs-list-folder-key-1965a46b-db4e-469e-aaaa-7e0b379cb34d-2.json"
    },
    {
      "match": "or jobs get 0f9d854e-221e-487d-bb2b-fcc76a7d7461 --output json",
      "file": "or-jobs-get-0f9d854e-221e-487d-bb2b-fcc76a7d7461-output-json.json"
    },
    {
      "match": "or jobs get --help",
      "file": "or-jobs-get-help.json",
      "exit_code": 1
    },
    {
      "match": "or jobs get 0f9d854e-221e-487d-bb2b-fcc76a7d7461 --all-fields",
      "file": "or-jobs-get-0f9d854e-221e-487d-bb2b-fcc76a7d7461-all-fields.json"
    },
    {
      "match": "or jobs history 0f9d854e-221e-487d-bb2b-fcc76a7d7461",
      "file": "or-jobs-history-0f9d854e-221e-487d-bb2b-fcc76a7d7461.json"
    },
    {
      "match": "or machines list --all-fields",
      "file": "or-machines-list-all-fields.json"
    },
    {
      "match": "or licenses info",
      "file": "or-licenses-info.json"
    }
  ],
  "unmocked_default": {
    "response": "[]\n",
    "exit_code": 0,
    "_doc": "Permissive fallback: any uip command not matched by `rules` returns an empty array. Lets the agent explore beyond the recorded path without aborting."
  }
}
