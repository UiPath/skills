{
  "version": "1.1.0",
  "settings": {
    "model": "gpt-5.4",
    "maxTokens": 128000,
    "temperature": 0,
    "engine": "basic-v2",
    "maxIterations": 25,
    "mode": "standard"
  },
  "inputSchema": {
    "type": "object",
    "properties": {
      "task": {
        "type": "string",
        "description": "Email task"
      }
    },
    "required": [
      "task"
    ]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "content": {
        "type": "string",
        "description": "Agent response"
      }
    }
  },
  "metadata": {
    "storageVersion": "50.0.0",
    "isConversational": false,
    "showProjectCreationExperience": false,
    "targetRuntime": "pythonAgent"
  },
  "type": "lowCode",
  "messages": [
    {
      "role": "system",
      "content": "Send the requested email update.",
      "contentTokens": [
        {
          "type": "simpleText",
          "rawString": "Send the requested email update."
        }
      ]
    },
    {
      "role": "user",
      "content": "{{input.task}}",
      "contentTokens": [
        {
          "type": "variable",
          "rawString": "input.task"
        }
      ]
    }
  ],
  "projectId": "99999999-9999-4999-8999-999999999999"
}
