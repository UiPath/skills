          "Data": {
            "JobKey": "b2c3d4e5-0000-0000-0000-000000000001",
            "FileName": "healing-agent-data-b2c3d4e5-0000-0000-0000-000000000001.zip",
            "Size": 254318,
            "ExportId": 4711
          }
        }
      }
    ],
    "Subcommands": [],
