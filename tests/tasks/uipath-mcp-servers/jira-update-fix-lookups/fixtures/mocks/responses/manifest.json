{
  "version": 2,
  "rules": [
    { "match": "mcp list --help",                                      "file": "mcp_list_help.txt" },
    { "match": "agenthub mcp list",                                    "file": "agenthub_mcp_list.json" },
    { "match": "agenthub mcp-tools create-is-activity --help",             "file": "create_is_activity_help.txt" },
    { "match": "agenthub mcp get test-mcp-skill",                         "file": "agenthub_mcp_get.json" },
    { "match": "agenthub mcp-tools list --mcp test-mcp-skill",            "file": "mcp_tools_list.json" },
    { "match": "agenthub mcp-tools candidates --category is-activity --connector uipath-atlassian-jira --folder-path Shared", "file": "candidates_is_activity_jira.json" },
    { "match": "agenthub mcp-tools candidates --category is-activity --folder-path Shared --connector uipath-atlassian-jira", "file": "candidates_is_activity_jira.json" },
    { "match": "agenthub mcp-tools candidates --category is-activity --connector uipath-atlassian-jira", "file": "candidates_is_activity_jira.json" },
    { "match": "agenthub mcp-tools candidates --category is-activity --folder-path Shared", "file": "candidates_is_activity_folder_shared.json" },
    { "match": "agenthub mcp-tools candidates --category is-activity", "file": "candidates_is_activity_folder_shared.json" },
    { "match": "agenthub mcp-tools get --help",                           "file": "mcp_tools_get_help.txt" },
    { "match": "agenthub mcp-tools get",                                  "file": "mcp_tools_get.json" },
    { "match": "is connections list uipath-atlassian-jira --folder-key folder-mock-shared", "file": "connections_list_jira_shared.json" },
    { "match": "is connections list uipath-atlassian-jira --folder-key folder-mock-demo", "file": "connections_list_jira_demo.json" },
    { "match": "is connections list uipath-atlassian-jira --all-folders", "file": "connections_list_jira_all_folders.json" },
    { "match": "is connections list uipath-atlassian-jira",               "file": "connections_list_jira_shared.json" },
    { "match": "is connections list --folder-key folder-mock-shared",     "file": "connections_list_shared.json" },
    { "match": "is connections list --folder-key folder-mock-demo",       "file": "connections_list_demo.json" },
    { "match": "is connections list --all-folders",                       "file": "connections_list_all_folders.json" },
    { "match": "is connections list",                                     "file": "connections_list_shared.json" },
    { "match": "is connections ping conn-mock-jira-01 --output json",      "file": "connection_ping_jira_enabled.json" },
    { "match": "is resources describe uipath-atlassian-jira curated_create_issue", "file": "describe_curated_create_issue.json" },
    { "match": "is resources run list uipath-atlassian-jira project",   "file": "run_list_project.json" },
    { "match": "is resources run list uipath-atlassian-jira issuetype", "file": "run_list_issuetype.json" },
    { "match": "agenthub mcp-tools update --help",                         "file": "mcp_tools_update_help.txt" },
    { "match": "agenthub mcp-tools update",                               "file": "mcp_tools_update_dryrun.json" }
  ],
  "unmocked_default": { "response": "{\"Result\":\"Failure\",\"Message\":\"command not mocked\"}\n", "exit_code": 1 }
}
