{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/ensure-uip.sh\"",
            "timeout": 180,
            "once": true,
            "statusMessage": "Checking uip, servo and rpa-tool installation..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/update-check.sh\"",
            "timeout": 30,
            "once": true,
            "statusMessage": "Checking for skills updates..."
          }
        ]
      }
    ]
  }
}
