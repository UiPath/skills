{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"${CLAUDE_PLUGIN_ROOT}/hooks/ensure-uip.ps1\"; if ($null -eq $LASTEXITCODE) { exit 1 } else { exit $LASTEXITCODE }",
            "timeout": 180,
            "once": true,
            "statusMessage": "Checking uip and rpa-tool installation..."
          },
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"${CLAUDE_PLUGIN_ROOT}/hooks/suggest-permissions.ps1\"",
            "timeout": 5,
            "once": true
          },
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"${CLAUDE_PLUGIN_ROOT}/hooks/set-session-env.ps1\"",
            "timeout": 5
          },
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"${CLAUDE_PLUGIN_ROOT}/hooks/send-telemetry.ps1\"",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"${CLAUDE_PLUGIN_ROOT}/hooks/send-telemetry.ps1\"",
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"${CLAUDE_PLUGIN_ROOT}/hooks/send-telemetry.ps1\"",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"${CLAUDE_PLUGIN_ROOT}/hooks/send-telemetry.ps1\"",
            "async": true
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"${CLAUDE_PLUGIN_ROOT}/hooks/send-telemetry.ps1\"",
            "async": true
          }
        ]
      }
    ]
  }
}
